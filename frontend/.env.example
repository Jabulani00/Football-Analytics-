# OddAlerts Football Data API token.
# Get yours from https://oddalerts.com and copy frontend/.env.example -> frontend/.env
#
# ODDALERTS_TOKEN          -> used by the server-side proxy (web). Keep secret.
# EXPO_PUBLIC_ODDALERTS_TOKEN -> used for direct calls on native (iOS/Android) dev.
#
# On Vercel, set ODDALERTS_TOKEN in Project Settings -> Environment Variables.

ODDALERTS_TOKEN=your_oddalerts_token_here
EXPO_PUBLIC_ODDALERTS_TOKEN=your_oddalerts_token_here

# Optional overrides:
# EXPO_PUBLIC_ODDALERTS_PROXY=/oddalerts
# EXPO_PUBLIC_ODDALERTS_BASE_URL=https://data.oddalerts.com/api
