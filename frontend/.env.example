# OddAlerts Football Data API token.
# Get yours from https://oddalerts.com and copy frontend/.env.example -> frontend/.env
#
# ODDALERTS_TOKEN          -> used by the server-side proxy (web). Keep secret.
# EXPO_PUBLIC_ODDALERTS_TOKEN -> used for direct calls on native (iOS/Android) dev.
#
# On Vercel, set ODDALERTS_TOKEN in Project Settings -> Environment Variables.

ODDALERTS_TOKEN=your_oddalerts_token_here
EXPO_PUBLIC_ODDALERTS_TOKEN=your_oddalerts_token_here

# Optional overrides:
# EXPO_PUBLIC_ODDALERTS_PROXY=/oddalerts
# EXPO_PUBLIC_ODDALERTS_BASE_URL=https://data.oddalerts.com/api

# Club badges (logos) via TheSportsDB. The public test key "123" works out of
# the box; set your own key for higher rate limits (https://www.thesportsdb.com/api.php).
# THESPORTSDB_KEY              -> used by the server-side /teamlogo proxy (web).
# EXPO_PUBLIC_THESPORTSDB_KEY  -> used for direct lookups on native.
# THESPORTSDB_KEY=123
# EXPO_PUBLIC_THESPORTSDB_KEY=123

# API-Football (api-sports.io) — goal scorers, assists, cards, subs on match summary.
# Free tier: 100 requests/day. Register at https://dashboard.api-football.com/register
# API_FOOTBALL_KEY              -> server proxy (web). Keep secret.
# EXPO_PUBLIC_API_FOOTBALL_KEY  -> native direct calls.
# API_FOOTBALL_KEY=your_api_football_key_here
# EXPO_PUBLIC_API_FOOTBALL_KEY=your_api_football_key_here
